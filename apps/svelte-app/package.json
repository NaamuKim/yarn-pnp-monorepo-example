{
  "name": "@mono/svelte-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3006",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf .svelte-kit dist"
  },
  "dependencies": {
    "@mono/api-client": "workspace:*",
    "@mono/ui": "workspace:*",
    "@mono/utils": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.0",
    "@sveltejs/kit": "^2.7.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.0"
  }
}
